{
  "name": "kanthord",
  "version": "27.8.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11.18.0"
  },
  "packageManager": "npm@11.18.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "verify:handoff": "node scripts/verify-handoff.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node src/main.ts",
    "verify": "npm run typecheck && npm test && npm run verify:handoff && npm run lint && node src/main.ts db status",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-boundaries": "^7.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "commander": "^15.0.0",
    "pino": "^10.3.1",
    "ulid": "^3.0.2",
    "yaml": "^2.9.0"
  },
  "allowScripts": {
    "@google/genai@1.52.0": true,
    "protobufjs@7.6.4": true,
    "protobufjs@7.6.5": true
  }
}
