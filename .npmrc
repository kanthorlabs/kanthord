# Supply-chain mitigation: cooldown on freshly published versions.
# npm only installs versions published more than N days ago, so a compromised
# release that gets yanked within the window is never pulled in.
# Requires npm >= 11.18 (the key is silently ignored by older npm; Node 24
# ships npm 10.x, so bump npm to activate). Value is in days; adjust as needed.
min-release-age=3
