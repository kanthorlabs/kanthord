# Kanthor Core — LOCAL DEVELOPMENT image (Podman, rootless).
#
# "No build": Node 24 runs the TypeScript sources directly (type-stripping), so
# there is NO tsc/compile step — fast rebuilds for local testing. Deps are
# installed with `npm ci` (all packages public). @ff-labs/fff-node ships a
# prebuilt native binary per platform (via ffi-rs); npm ci pulls the matching
# linux binary as an optional dependency — verified in-container by Epic 020 SU2.
#
# Sandbox rule (unchanged): source is COPYed into the image, never bind-mounted;
# the ONLY host path mounted at runtime is .data/ (mounted at /data). The pi
# agent's shell/filesystem tools can damage only the container, never the host.
#
# Run (see scripts/dev/run-core-dev.sh):
#   podman run --rm -it --userns=keep-id \
#     -v "$PWD/.data:/data:Z" \
#     -e KANTHOR_IDENTITY_KANTHORDVERIFY_TOKEN=<pat> \
#     kanthord-core-dev \
#     node src/cli/run.ts --slot /data/kanthord/slots/kanthord-verify.yaml \
#       --account codex --model gpt-5.5
FROM docker.io/library/node:24-slim

# git + gh: the broker shells out to both. gh is not in Debian repos, so pull
# the pinned release tarball for the image arch.
ARG GH_VERSION=2.63.2
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates curl \
 && arch="$(dpkg --print-architecture)" \
 && case "$arch" in amd64) gharch=amd64 ;; arm64) gharch=arm64 ;; *) echo "unsupported arch $arch" >&2; exit 1 ;; esac \
 && curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${gharch}.tar.gz" -o /tmp/gh.tgz \
 && tar -xzf /tmp/gh.tgz -C /tmp \
 && install "/tmp/gh_${GH_VERSION}_linux_${gharch}/bin/gh" /usr/local/bin/gh \
 && rm -rf /tmp/gh* \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Dep layer first for cache reuse. .npmrc carries the min-release-age policy.
COPY package.json package-lock.json .npmrc ./
RUN npm ci

# Source (type-stripped at runtime; no build step).
COPY tsconfig.json ./
COPY src ./src

# Provider account (KANTHORD_DATA) lives under the shared /data mount so the
# host-registered `codex` account is visible in the container. The git identity
# token is injected per-run as KANTHOR_IDENTITY_<NAME>_TOKEN (never baked in).
ENV NODE_ENV=development \
    KANTHORD_DATA=/data/kanthord-auth

EXPOSE 7777

# Default: print usage. The daemon is launched with explicit args at `podman run`
# time (slot / account / model), so the image stays generic.
CMD ["node", "src/cli/run.ts", "--help"]
