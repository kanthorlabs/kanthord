# Kanthord web dashboard development image. Source is copied into the image so
# the runtime keeps the same no-host-source-mount boundary as Core.
FROM docker.io/library/node:24-slim

WORKDIR /app/clients/web

ARG NPM_VERSION=11.18.0
RUN npm install --global "npm@${NPM_VERSION}"

COPY clients/web/package.json clients/web/package-lock.json ./
RUN npm ci

COPY --chown=node:node clients/web/index.html clients/web/tsconfig.json clients/web/vite.config.ts ./
COPY --chown=node:node clients/web/src ./src
RUN chown -R node:node node_modules

USER node

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
